# SpashtAI production server — copy to apps/server/.env
# AWS LLMs only — no Ollama / local STT / local TTS

NODE_ENV=production
PORT=4000
FRONTEND_URL=https://spasht.ai

# Match infra/ec2/env/postgres.env
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/spashtai?schema=public

# LiveKit (keys must match infra/livekit/livekit.yaml)
# Public URL for browsers (via Cloudflare/Nginx)
LIVEKIT_URL=wss://livekit.spasht.ai
# Server-side SDK on EC2 — local docker (agent uses this too)
LIVEKIT_INTERNAL_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# AWS — Bedrock (Nova Sonic live voice, Nova Pro Replay/coaching), S3, Transcribe
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_REGION=us-east-1
BEDROCK_NOVASONIC_MODEL_ID=amazon.nova-sonic-v1:0
BEDROCK_REPLAY_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_COACHING_MODEL_ID=amazon.nova-pro-v1:0

# Coaching insights — AWS only in prod (do not use local-audio / Ollama)
INSIGHT_PROVIDER=bedrock-text
INSIGHT_REQUEST_TIMEOUT_MS=120000
INSIGHT_AUDIO_MAX_BYTES=15728640

# Gentle forced alignment (delivery metrics) — local docker on EC2
GENTLE_URL=http://127.0.0.1:8765

# Auth
JWT_SECRET=
GOOGLE_CLIENT_ID=

# Agent ↔ server (same value in apps/agent/.env)
INTERNAL_AGENT_TOKEN=

# S3 (Elevate recordings + Replay transcribe — same bucket in prod)
S3_BUCKET_PROD=spashtai-s3-prod

# Admin — do not auto-seed in production (use admin UI or a one-off script instead).
# To bootstrap the first admin once: SEED_ADMIN=true and ADMIN_PASSWORD=<strong>, restart API, then unset both.
# SEED_ADMIN=
# ADMIN_PASSWORD=
