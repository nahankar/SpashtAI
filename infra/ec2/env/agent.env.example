# SpashtAI production agent — copy to apps/agent/.env
# Voice: nova-sonic (AWS Bedrock) — do not run start-local-stack.sh

ENVIRONMENT=production
FORCE_LOCAL_STORAGE=false

# Agent connects to LiveKit docker on the same EC2 host (not public DNS)
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

SERVER_URL=https://api.spasht.ai
INTERNAL_AGENT_TOKEN=

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_REGION=us-east-1

AUDIO_S3_BUCKET=spashtai-s3-prod

LOG_LEVEL=INFO
WORKER_TYPE=spashtai-interview-agent
