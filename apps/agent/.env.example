# SpashtAI Environment Configuration
# Based on LiveKit official patterns: https://docs.livekit.io/agents/start/voice-ai/

# LiveKit Configuration (Required)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# AWS Configuration (Polly TTS, Transcribe streaming STT, Bedrock LLM)
# Region is always required.
AWS_REGION=us-east-1
BEDROCK_REGION=us-east-1
#
# Credentials: ON EC2 (production), DO NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
# Leave them unset/commented so all AWS SDKs (including the smithy-based Transcribe
# streaming client) use the EC2 instance role via the default credential chain.
# Setting them to EMPTY strings breaks Transcribe streaming with
# "UnrecognizedClientException" (the empty token is sent as invalid credentials),
# even though Polly/boto3 silently falls back to the instance role.
# Only set explicit keys for LOCAL development without an instance role:
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
BEDROCK_PIPELINE_LLM=amazon.nova-lite-v1:0

# Pipeline Bedrock (when admin activates pipeline-bedrock backend)
PIPELINE_STT_URL=http://localhost:8001/v1
PIPELINE_TTS_URL=http://localhost:8002/v1

# Optional: OpenAI (if using mixed providers)
# OPENAI_API_KEY=your_openai_key

# Optional: Other providers
# DEEPGRAM_API_KEY=your_deepgram_key
# CARTESIA_API_KEY=your_cartesia_key

# Agent Configuration
LOG_LEVEL=INFO
WORKER_TYPE=spashtai-interview-agent