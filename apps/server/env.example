# Server
PORT=4000
FRONTEND_URL=http://localhost:5173

# PostgreSQL — local dev (npm run dev:postgres from repo root)
# Prod: postgresql://USER:PASSWORD@YOUR_EC2_HOST:5432/spashtai?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spashtai?schema=public

# LiveKit (RTC)
LIVEKIT_URL=wss://your-livekit-url
LIVEKIT_API_KEY=lk_api_key
LIVEKIT_API_SECRET=lk_api_secret

# AWS / Bedrock (NovaSonic)
# Never expose these in the frontend. Used only on the server.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Bedrock model configuration (example keys; adjust to your setup)
BEDROCK_REGION=us-east-1
BEDROCK_NOVASONIC_MODEL_ID=amazon.nova-sonic-v1
BEDROCK_REPLAY_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_COACHING_MODEL_ID=amazon.nova-pro-v1:0

# Coaching insights (step 4) — local-audio | bedrock-text | bedrock-audio
# Local dev (no AWS for narratives): local-audio + Ollama
INSIGHT_PROVIDER=local-audio
LOCAL_AUDIO_INSIGHT_URL=http://localhost:11434/v1
LOCAL_AUDIO_INSIGHT_MODEL=qwen2.5:14b
LOCAL_TEXT_INSIGHT_MODEL=qwen2.5:14b
# Prod (when ready): bedrock-text (default) or bedrock-audio
# INSIGHT_PROVIDER=bedrock-text
# BEDROCK_COACHING_AUDIO_MODEL_ID=amazon.nova-2-sonic-v1:0
INSIGHT_REQUEST_TIMEOUT_MS=120000
INSIGHT_AUDIO_MAX_BYTES=15728640

# Python signal extraction API (agent worker)
SIGNAL_API_URL=http://localhost:4001

# Google Sign-In (GIS — same Web Client ID on server + frontend build)
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
# Frontend build-time (apps/web): VITE_GOOGLE_CLIENT_ID=<same value as above>
# Frontend build-time: VITE_API_BASE_URL=https://api.spasht.ai

# Gentle forced alignment (delivery WPM/pauses) — optional local docker
GENTLE_URL=http://localhost:8765

# JWT (required in production — use a long random secret)
JWT_SECRET=dev-secret-change-me

