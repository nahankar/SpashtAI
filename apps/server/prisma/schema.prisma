generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique

  // Authentication
  passwordHash          String?
  googleId              String?   @unique
  emailVerified         Boolean   @default(false)
  verificationToken     String?   @unique
  resetPasswordToken    String?   @unique
  resetPasswordExpiry   DateTime?

  // Profile
  firstName     String?
  lastName      String?
  avatar        String?
  phone         String?
  dateOfBirth   DateTime?
  gender        Gender?
  pincode       String?
  city          String?   // resolved from pincode — admin only
  state         String?   // admin only
  country       String?   // admin only

  // Authorization
  role          UserRole @default(USER)

  // Activity
  lastLoginAt   DateTime?
  lastActiveAt  DateTime?
  loginCount    Int      @default(0)
  rewardPoints  Float    @default(0)

  // Per-user content/export restrictions (admin-controlled).
  // "hide*" gate VIEWING of transcript/audio content (default: visible).
  hideTranscriptText       Boolean @default(false)
  hideTranscriptJsonExport Boolean @default(false)
  hideAudioDownload        Boolean @default(false)

  // Per-user export/reprocess capabilities (admin-controlled).
  // "enable*" gate the download/reprocess ACTION BUTTONS and endpoints.
  // Default OFF — these only appear once an admin enables them (admins always
  // have them). Independent from the "hide*" view flags above.
  enableTxtExport   Boolean @default(false)
  enableJsonExport  Boolean @default(false)
  enableAudioExport Boolean @default(false)
  enableReprocess   Boolean @default(false)

  // Pro license (admin-controlled). Gates premium UI features such as
  // playback "Key Moments" and the "Ask AI Coach" assistant. Default OFF;
  // admins always have access regardless of this flag.
  enablePro         Boolean @default(false)

  // Ultra license (admin-controlled). Gates the highest-tier features such as
  // Replay video-file uploads. Default OFF; admins always have access.
  enableUltra       Boolean @default(false)

  // Relations
  sessions       Session[]
  replaySessions ReplaySession[]
  activityLogs   UserActivity[]
  featureUsage   FeatureUsage[]
  progressPulse  ProgressPulse[]
  feedback         UserFeedback[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model FeatureUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  feature   String
  action    String

  sessionId String?
  metadata  Json?
  duration  Int?

  timestamp DateTime @default(now())

  @@index([userId, feature, timestamp])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  action    String
  resource  String?
  resourceId String?

  ipAddress String?
  userAgent String?
  metadata  Json?

  timestamp DateTime @default(now())

  @@index([userId, timestamp])
}

model AdminAction {
  id        String   @id @default(cuid())
  adminId   String

  action    String
  targetUserId   String?
  targetResource String?

  reason    String?  @db.Text
  metadata  Json?

  timestamp DateTime @default(now())

  @@index([adminId, timestamp])
}

model SystemMetrics {
  id        String   @id @default(cuid())
  date      DateTime @unique

  totalUsers          Int
  activeUsers         Int
  newUsers            Int

  replayUploads       Int
  elevateSessions     Int
  totalMinutesAnalyzed Int

  avgResponseTime     Float?
  errorRate           Float?

  createdAt DateTime @default(now())

  @@index([date])
}

model Session {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  module      String   // elevate | pitch | fluency
  sessionName String?
  focusArea   String?  // e.g. clarity, confidence, filler_words
  focusContext String? // free-text context from Replay C2A or user input
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  durationSec Int?
  sessionPointsAwarded Boolean @default(false)

  viewCount    Int       @default(0)
  lastViewedAt DateTime?

  progressPulseStatus String? // 'tracked' | 'skipped' | null (not yet decided)

  // Shared audio timeline anchor (t0): all SessionTurn.audioStart/audioEnd and
  // word timings are expressed as seconds since this instant, aligned to the
  // start of the streamable recording so the replay UI can seek directly.
  recordingStartedAt DateTime?

  // Relations
  metrics     SessionMetrics?
  transcript  SessionTranscript?
  recordings  SessionRecording[]
  turns       SessionTurn[]

  @@index([userId, startedAt])
}

// Per-turn record powering the "conversation as replay" UX (per-message audio
// offsets, word timings, metrics, scores, coach notes). Session-level rollups
// stay in SessionMetrics; this is the queryable per-answer primary object.
model SessionTurn {
  id        String   @id @default(cuid())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String

  turnIndex Int      // 0-based order within the session (reconciled with messages[])
  role      String   // 'user' | 'assistant'
  text      String   @db.Text

  // Audio timeline (seconds since Session.recordingStartedAt). Null when timing
  // could not be measured/aligned (e.g. backend without word timestamps).
  audioStart Float?
  audioEnd   Float?

  words   Json?    // [{ w: string, start: number, end: number }] (user turns only, v1)
  metrics Json?    // TurnMetricsSnapshot: { wpm, fillerCount, fillerRate, hedgingCount, vocabDiversity, speakingSeconds, ... }
  score   Json?    // LLM judge: { stars, confidence, tags: string[] }
  coachNote String? @db.Text

  createdAt DateTime @default(now())

  @@unique([sessionId, turnIndex])
  @@index([sessionId])
}

model SessionMetrics {
  id        String   @id @default(cuid())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String   @unique
  
  // LiveKit metrics
  totalLlmTokens        Int     @default(0)
  totalLlmDuration      Float   @default(0)
  avgTtft              Float   @default(0)  // time to first token
  totalTtsDuration     Float   @default(0)
  totalTtsAudioDuration Float   @default(0)
  avgTtsTtfb           Float   @default(0)  // time to first byte
  totalEouDelay        Float   @default(0)  // end of utterance delay
  conversationLatencyAvg Float @default(0)
  
  // User linguistic metrics
  userWpm              Float   @default(0)
  userFillerCount      Int     @default(0)
  userFillerRate       Float   @default(0)
  userAvgSentenceLength Float  @default(0)
  userSpeakingTime     Float   @default(0)
  userVocabDiversity   Float   @default(0)
  userResponseTimeAvg  Float   @default(0)
  
  // Assistant linguistic metrics
  assistantWpm         Float   @default(0)
  assistantFillerCount Int     @default(0)
  assistantFillerRate  Float   @default(0)
  assistantAvgSentenceLength Float @default(0)
  assistantSpeakingTime Float  @default(0)
  assistantVocabDiversity Float @default(0)
  assistantResponseTimeAvg Float @default(0)
  
  totalTurns           Int     @default(0)
  
  // Advanced analytics (spaCy, Praat, Gentle)
  contentMetrics       Json?   // NLP analysis: vocabulary, grammar, entities
  deliveryMetrics      Json?   // Audio analysis: prosody, pauses, speech rate
  performanceInsights  Json?   // Comprehensive scoring and feedback
  processingStatus     Json?   // Track what's been processed

  // Metrics Engine v2: skill-based scoring
  skillScores          Json?   // 8 skill scores (clarity, confidence, etc.)
  communicationSignals Json?   // Raw signal extraction output from spaCy/textstat
  coachingInsights     Json?   // AI-generated coaching feedback
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt
}

model SessionTranscript {
  id        String   @id @default(cuid())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String   @unique
  
  // Full conversation data as JSON
  conversationData Json
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SessionRecording {
  id         String   @id @default(cuid())
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId  String   // Removed @unique to allow multiple recordings per session
  
  // Egress recording details
  egressId   String   @unique
  filePath   String   // Local path or S3 URL
  duration   Int      @default(0)  // Duration in seconds
  fileSize   Int      @default(0)  // File size in bytes
  status     String   @default("completed")  // completed, failed, processing
  recordingType String @default("user")  // user, agent, merged
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Replay Feature ──

model ReplaySession {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String

  sessionName      String?
  meetingType      String
  userRole         String
  focusAreas       String[]
  meetingGoal      String?
  meetingDate      DateTime?
  participantName  String?

  // pending | transcribing | analyzing | completed | failed
  status       String   @default("pending")
  errorMessage String?

  viewCount    Int       @default(0)
  exportCount  Int       @default(0)

  progressPulseStatus String? // 'tracked' | 'skipped' | null (not yet decided)

  uploadedFiles ReplayUpload[]
  result        ReplayResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model ReplayUpload {
  id              String        @id @default(cuid())
  replaySession   ReplaySession @relation(fields: [replaySessionId], references: [id], onDelete: Cascade)
  replaySessionId String

  fileType     String   // audio | video | transcript | text
  originalName String
  storedPath   String
  fileSize     Int
  mimeType     String
  duration     Float?   // seconds, for audio/video

  createdAt DateTime @default(now())
}

model ReplayResult {
  id              String        @id @default(cuid())
  replaySession   ReplaySession @relation(fields: [replaySessionId], references: [id], onDelete: Cascade)
  replaySessionId String        @unique

  // Transcript
  transcriptText       String  @db.Text
  structuredTranscript Json?
  speakerCount         Int     @default(1)
  transcriptionSource  String  // aws_transcribe | uploaded | pasted

  // Computed metrics
  wordsPerMinute      Float   @default(0)
  fillerWordCount     Int     @default(0)
  fillerWordRate      Float   @default(0)
  avgSentenceLength   Float   @default(0)
  vocabularyDiversity Float   @default(0)
  totalTurns          Int     @default(0)
  speakingPercentage  Float   @default(0)

  // Confidence signals
  hedgingCount        Int     @default(0)
  hedgingRate         Float   @default(0)

  // Behavioral metrics
  interruptionCount   Int     @default(0)
  longestMonologueSec Int     @default(0)
  questionsAsked      Int     @default(0)
  repetitionRequests  Int     @default(0)
  avgResponseTimeSec  Float?

  // AI scores (1-10)
  overallScore    Float @default(0)
  clarityScore    Float @default(0)
  confidenceScore Float @default(0)
  engagementScore Float @default(0)

  // AI-generated feedback (JSON arrays / objects)
  strengths               Json?
  improvements            Json?
  recommendations         Json?
  contextSpecificFeedback Json?
  keyMoments              Json?
  annotatedTranscript     Json?

  // Metrics Engine v2: skill-based scoring (shared with Elevate)
  skillScores          Json?
  communicationSignals Json?
  coachingInsights     Json?

  // Model / cost tracking
  modelUsed        String?
  promptTokens     Int     @default(0)
  completionTokens Int     @default(0)
  processingTimeMs Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── My Progress Pulse ──

model ProgressPulse {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  skill     String   // clarity, confidence, filler_words, engagement, pacing, structure, conciseness, action_items
  score     Float    // 0-10 scale
  source    String   // 'replay' | 'elevate'
  sessionId String?  // references the originating session (Replay or Elevate)

  metadata  Json?    // extra context (e.g. wpm, fillerRate, raw metric values)

  recordedAt DateTime @default(now())

  @@index([userId, skill, recordedAt])
  @@index([userId, recordedAt])
}

// ── Platform feature flags (global until multi-tenant) ──
model PlatformFeatureFlag {
  feature          String   @unique // "elevate" | "replay"
  label            String
  description      String?  @db.Text
  enabled          Boolean  @default(true) // legacy; migrated to hidden/disabled
  hidden           Boolean  @default(false)
  disabled         Boolean  @default(false)
  overlayComment   String?  @db.Text
  overlayPosition  String   @default("center") // top | center
  updatedBy        String?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

// Admin-editable LLM prompts for the live Elevate coach (agent loads at session start).
model AgentPrompt {
  key         String   @unique // e.g. elevate_coach_persona, elevate_exercise_filler_words
  label       String
  description String?  @db.Text
  content     String   @db.Text
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// ── Voice Backend Configuration ──
// Admin-selectable backend powering the Elevate live coach.
// Multiple presets are seeded; the row with isActive=true is what the agent uses.
model VoiceConfig {
  id          String  @id @default(cuid())
  // "nova-sonic" | "pipeline-premium" (extensible)
  backend     String  @unique
  displayName String
  description String? @db.Text

  // Per-backend tuning (NULL when not applicable)
  pipelineStt String? // e.g. "whisper-large-v3-turbo"
  pipelineLlm String? // e.g. "amazon.nova-pro-v1:0"
  pipelineTts String? // e.g. "kokoro" | "polly"
  voiceName   String? // e.g. "tiffany" (Nova Sonic) | "af_bella" (Kokoro) | "Ruth" (Polly)

  // Composable providers for pipeline-bedrock (whisper|transcribe, kokoro|polly)
  sttProvider String? // whisper | transcribe
  ttsProvider String? // kokoro | polly

  // Endpoints for local pipeline servers (only used by pipeline-* backends)
  sttBaseUrl String? // e.g. "http://localhost:8001/v1"
  llmBaseUrl String? // e.g. "http://localhost:11434/v1"
  ttsBaseUrl String? // e.g. "http://localhost:8002/v1"

  isActive  Boolean  @default(false)
  updatedBy String? // admin user id who last changed it
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Singleton (id = "default") admin config for the Replay/analysis LLM.
// Separate from VoiceConfig (which only drives the live Elevate voice agent).
model AnalysisConfig {
  id            String   @id @default("default")
  // Bedrock model id for Replay transcript analysis + coaching insights.
  // NULL = fall back to the BEDROCK_REPLAY_MODEL_ID env default.
  replayModelId String?
  updatedBy     String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

enum UserFeedbackType {
  FEEDBACK
  ISSUE
  FEATURE_REQUEST
}

enum UserFeedbackStatus {
  OPEN
  ACKNOWLEDGED
  CONSIDERED
  IMPLEMENTED
  PARKED
}

enum FeedbackPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model UserFeedback {
  id             String              @id @default(cuid())
  feedbackNumber String              @unique
  userId         String
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           UserFeedbackType    @default(FEEDBACK)
  subject        String?
  body           String              @db.Text
  status         UserFeedbackStatus  @default(OPEN)
  priority       FeedbackPriority?
  pointsAwarded  Boolean             @default(false)
  acknowledgedAt DateTime?
  attachments    UserFeedbackAttachment[]
  notes          UserFeedbackNote[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([userId, createdAt])
  @@index([status])
  @@index([status, priority])
}

model UserFeedbackAttachment {
  id          String       @id @default(cuid())
  feedbackId  String
  feedback    UserFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  fileName    String
  mimeType    String
  storedPath  String
  createdAt   DateTime     @default(now())
}

model UserFeedbackNote {
  id         String       @id @default(cuid())
  feedbackId String
  feedback   UserFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  authorId   String
  isAdmin    Boolean      @default(false)
  body       String       @db.Text
  createdAt  DateTime     @default(now())
}

model PlatformTicker {
  id        String   @id @default(cuid())
  message   String   @db.Text
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformSettings {
  id                   String   @id @default("default")
  signupsPaused        Boolean  @default(false)
  signupsPausedMessage String?  @db.Text
  updatedBy            String?
  updatedAt            DateTime @updatedAt
}

model PricingSettings {
  id             String  @id @default("default")
  enabled        Boolean @default(false)
  comingSoonText String? @db.Text
  updatedAt      DateTime @updatedAt
}

model PricingPlan {
  id           String   @id @default(cuid())
  name         String
  priceMonthly Float
  description  String?  @db.Text
  isPromoted   Boolean  @default(false)
  sortOrder    Int      @default(0)
  features     PricingPlanFeature[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PricingPlanFeature {
  id        String      @id @default(cuid())
  planId    String
  plan      PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  text      String
  sortOrder Int         @default(0)
}

model LegalDocument {
  id        String   @id @default(cuid())
  slug      String   @unique // terms | privacy
  title     String
  content   String   @db.Text
  updatedAt DateTime @updatedAt
  updatedBy String?
}
